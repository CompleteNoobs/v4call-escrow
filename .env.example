# ── v4call-escrow — the isolated money box .env ───────────────────────────────
# Copy to .env and fill in. This host holds the ONLY active money key. Keep it
# minimal, patched, and free of dev tooling (no Claude on the money box).

# The escrow Hive account that RECEIVES payments and SENDS settlements.
ESCROW_ACCOUNT=v4call-escrow

# Billing currency. HBD/HIVE are native (precision 3). For a Hive-Engine token,
# also set ESCROW_TOKEN_PRECISION to its on-chain precision.
ESCROW_CURRENCY=HBD
# ESCROW_TOKEN_PRECISION=3

# ⚠ THE MONEY KEY — the escrow account's ACTIVE key (starts 5K/5J). This is the
# whole point of the isolated box: this key lives HERE and nowhere else. The node
# holds NO money key. Never commit this; never share it.
V4CALL_ESCROW_KEY=5Kxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Platform-fee recipient (the operator's Hive account — where ring fee + the % cut go).
FEE_ACCOUNT=yourplatformaccount

# Durable ledger + the box's own reporting key (schnorr). Under ./data by default
# so a `docker compose down` keeps them; back up the ledger like real money.
ESCROW_DB_PATH=/app/data/v4call-escrow.db
ESCROW_KEY_PATH=/app/data/escrow-reporting-key.json

# The Nostr relays (nGate) the box subscribes on for event-reports / publishes receipts to.
# Use relays YOU control; add a second for redundancy when you stand one up.
NOSTR_RELAYS=wss://nostr.v4call.com

# ⚠ FAIL-CLOSED TRUST: the node escrow-reporting pubkey(s) this box accepts reports
# from (64-hex schnorr, on-chain-bound via the node's Hive announcement). Comma-separated.
# A report signed by any other key is rejected. REQUIRED.
ESCROW_EXPECTED_REPORTERS=

# Cap on metered duration (minutes) — matches the node's MAX_CALL_DURATION_MIN.
MAX_CALL_DURATION_MIN=120

# Operational (optional): override the Hive API node, HE retry tuning, etc.
# HIVE_API=https://api.hive.blog
